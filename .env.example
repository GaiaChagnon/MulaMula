# Copy to `.env.local` and fill in values.

# --- App (public, safe in the browser) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- OpenRouter (server only) — formats chat answers; facts come from the finance engine ---
OPENROUTER_API_KEY=
# Model id: https://openrouter.ai/models
# Default is Moonshot Kimi K2.6 (fast, tool-capable)
OPENROUTER_MODEL=moonshotai/kimi-k2.6
# Optional: shown on OpenRouter as the request referer (defaults to NEXT_PUBLIC_APP_URL, then Vercel URL, then localhost)
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=MoneyTalkz

# OpenRouter TTS model for Greta (default: google/gemini-3.1-flash-tts-preview)
# Leave blank to use the default.
OPENROUTER_TTS_MODEL=
# Optional voice id override (default: Kore). Gemini voices: Puck, Charon, Kore, Fenrir, Aoede, ...
OPENROUTER_TTS_VOICE=
