# Copy to `.env.local` and fill in values.

# --- App (public, safe in the browser) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- OpenRouter (server only) — formats chat answers; facts come from the finance engine ---
OPENROUTER_API_KEY=
# Model id: https://openrouter.ai/models
# Default is Moonshot Kimi K2.5 (fast, tool-capable, ~$0.44/M in, $2/M out)
OPENROUTER_MODEL=moonshotai/kimi-k2.5
# Optional: shown on OpenRouter as the request referer (defaults to NEXT_PUBLIC_APP_URL, then Vercel URL, then localhost)
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=MoneyTalkz

# OpenRouter TTS model for Greta (default: openai/gpt-4o-mini-tts, ~$0.60 / 1M chars)
# Leave blank to use the default.
OPENROUTER_TTS_MODEL=
